<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <targets>
    <!-- Console: coloured output for the live demo -->
    <target xsi:type="ColoredConsole" name="console"
            layout="${time} [${level:uppercase=true}] ${logger:shortName=true} ${message}">
      <highlight-row condition="level == LogLevel.Info"  foregroundColor="Green" />
      <highlight-row condition="level == LogLevel.Warn"  foregroundColor="Yellow" />
      <highlight-row condition="level == LogLevel.Error" foregroundColor="Red" />
    </target>

    <!-- File: rolling log with full exception chain and structured properties -->
    <target xsi:type="File" name="file"
            fileName="logs/app.log"
            layout="${longdate}|${level:uppercase=true}|${logger}|${message}|${all-event-properties}${onexception:${newline}${exception:format=tostring:maxInnerExceptionLevel=5}}" />
  </targets>

  <rules>
    <logger name="*" minlevel="Info" writeTo="console,file" />
  </rules>

</nlog>
